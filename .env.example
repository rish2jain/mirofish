# ===== LLM Configuration =====
# Supports OpenAI, Anthropic (Claude), or any OpenAI-compatible API.
# Note: simulations consume significant tokens. Start with <40 rounds.
#
# CLI-FIRST AUTO-DETECTION:
# Leave LLM_PROVIDER blank to auto-detect local CLIs in priority order:
#   Claude CLI → Codex CLI → Gemini CLI → API fallback
# If no CLI is found and no API key is set, startup fails with a clear error.

# Provider: 'openai', 'anthropic', 'claude-cli', 'codex-cli', 'gemini-cli',
#           or leave blank for auto-detection
# LLM_PROVIDER=
LLM_PROVIDER=anthropic

# For Anthropic (Claude):
LLM_API_KEY=your_anthropic_api_key_here
LLM_MODEL_NAME=claude-sonnet-4-20250514

# For OpenAI:
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# For OpenAI-compatible providers (e.g., OpenRouter):
# LLM_API_KEY=sk-or-your-key
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=anthropic/claude-sonnet-4-20250514

# For Docker + Codex CLI via codex-proxy:
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://codex-proxy:11435/v1
# LLM_API_KEY=codex
# LLM_MODEL_NAME=codex

# ===== CLI Proxy Configuration (Docker only) =====
CODEX_PROXY_WORKERS=4
CODEX_PROXY_TIMEOUT=180
CLAUDE_PROXY_WORKERS=4
CLAUDE_PROXY_TIMEOUT=120
GEMINI_PROXY_WORKERS=4
GEMINI_PROXY_TIMEOUT=180

# ===== Graph Database Configuration =====
# KuzuDB (embedded, no external service needed)
GRAPH_BACKEND=kuzu
KUZU_DB_PATH=./data/kuzu_db
# DATA_DIR=./data/json_graphs

# ===== OASIS Simulation Configuration =====
OASIS_DEFAULT_MAX_ROUNDS=10

# ===== Report Agent Configuration =====
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
# Optional: generate report sections in parallel (faster; uses outline-only cross-section context)
# REPORT_SECTION_PARALLEL=true
# REPORT_SECTION_PARALLEL_MAX_WORKERS=4
# Optional: parallel InsightForge sub-query graph searches (default on)
# INSIGHT_FORGE_PARALLEL_SUBQUERIES=false
# INSIGHT_FORGE_SUBQUERY_WORKERS=4

# ===== Frontend (Vite) — optional =====
# Set to 0 or false to force HTTP polling for simulation run status (default: use SSE when supported)
# VITE_SIMULATION_SSE=false
# Set to 0 or false to force HTTP polling for report agent/console logs (default: use SSE when supported)
# VITE_REPORT_LOG_SSE=false
# Set to 0 or false to force HTTP polling for graph build task progress on MainView (default: use SSE when supported)
# VITE_GRAPH_TASK_SSE=false

# ===== Performance Optimization =====
# LLM response cache: content-hash based, file-backed (uploads/llm_cache/)
# Saves redundant LLM calls for identical prompts (e.g. re-extracting same doc)
# LLM_CACHE_ENABLED=true
# LLM_CACHE_MAX_AGE=604800     # Cache TTL in seconds (default: 7 days)

# Parallel entity extraction: process text chunks concurrently (3-5x speedup)
# PARALLEL_ENTITY_EXTRACTION=true
# PARALLEL_ENTITY_EXTRACTION_WORKERS=4

# CLI subprocess timeout in seconds (applies to claude/codex/gemini CLI calls)
# CLI_TIMEOUT=180

# ===== Shared deployment / integrations (optional) =====
# When set, sensitive routes require: Authorization: Bearer <same value>
# (template write, import bundle, webhook registry, batch create)
# MIROFISH_API_KEY=
# Allow PUT/POST /api/templates/* without FLASK_DEBUG (still needs key if MIROFISH_API_KEY set)
# MIROFISH_ALLOW_TEMPLATE_WRITE=false
# When true, POST /api/graph/project/import-bundle requires X-MiroFish-User
# MIROFISH_REQUIRE_USER_HEADER=false
# Max items per POST /api/simulation/batch/create
# BATCH_SIM_MAX_ITEMS=20

# ===== Flask Configuration =====
# SECRET_KEY=...            # If unset, a key is stored at backend/config/secrets/.secret_key (not under uploads)
# MIROFISH_APP_CONFIG_DIR=  # Optional override for config root (default: backend/config). Secrets: <root>/secrets/
# APP_CONFIG_DIR=
# CONFIG_DIR=
# FLASK_DEBUG=true
# EXPOSE_BINARY_PATH=true   # if set, /health includes llm_binary path; otherwise only llm_cli_on_path (bool)
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5001

# ===== Accelerated LLM Configuration (optional) =====
# If not using boost config, remove these lines entirely
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
