  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
